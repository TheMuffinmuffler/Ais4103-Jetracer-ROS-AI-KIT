<?xml version="1.0"?>
<launch>
    <!-- 1. Start the SLAM System (Bypassing youssef_slam.launch to fix Gmapping frames) -->
    
    <!-- Gmapping: Fixed directly here to match robot_pose_ekf's /odom frame -->
    <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
        <remap from="scan" to="scan"/>
        <param name="base_frame" value="base_footprint"/>
        <param name="odom_frame" value="odom"/> 
        <param name="map_update_interval" value="2.0"/>
        <param name="maxUrange" value="8.0"/>
        <param name="maxRange" value="12.0"/>
        <param name="sigma" value="0.05"/>
        <param name="kernelSize" value="1"/>
        <param name="lstep" value="0.05"/>
        <param name="astep" value="0.05"/>
        <param name="iterations" value="5"/>
        <param name="lsigma" value="0.075"/>
        <param name="ogain" value="3.0"/>
        <param name="lskip" value="0"/>
        <param name="minimumScore" value="100"/>
        <param name="srr" value="0.10"/>
        <param name="srt" value="0.12"/>
        <param name="str" value="0.10"/>
        <param name="stt" value="0.12"/>
        <param name="linearUpdate" value="0.20"/>
        <param name="angularUpdate" value="0.15"/>
        <param name="temporalUpdate" value="1.0"/>
        <param name="resampleThreshold" value="0.5"/>
        <param name="particles" value="20"/>
        <param name="xmin" value="-50.0"/>
        <param name="ymin" value="-50.0"/>
        <param name="xmax" value="50.0"/>
        <param name="ymax" value="50.0"/>
        <param name="delta" value="0.05"/>
        <param name="llsamplerange" value="0.01"/>
        <param name="llsamplestep" value="0.01"/>
        <param name="lasamplerange" value="0.005"/>
        <param name="lasamplestep" value="0.005"/>
    </node>

    <!-- Map Manager/Saver (The logic from youssef_slam) -->
    <node pkg="ris" type="youssef_slam" name="youssef_slam" output="screen">
        <param name="map_topic" value="/map"/>
        <param name="laptop_map_dir" value="/home/jetson/maps"/>
        <param name="laptop_map_name" value="mymap"/>
        <param name="robot_map_dir" value="/home/jetson/maps"/>
        <param name="robot_user" value="jetson"/>
        <param name="robot_ip" value="192.168.0.144"/>
        <param name="check_period_sec" value="2.0"/>
        <param name="changed_cells_threshold" value="20"/>
        <param name="stable_seconds_before_save" value="12.0"/>
        <param name="min_exploration_time_sec" value="90.0"/>
        <param name="gmapping_node_name" value="/slam_gmapping"/>
        <param name="stop_robot_before_save" value="true"/>
        <param name="exploration_done_topic" value="/exploration_done"/>
        <param name="publish_exploration_done" value="true"/>
    </node>

    <!-- 2. Start the ArUco Vision System (Processor, Saver, and Transforms) -->
    <include file="$(find ris)/launch/ris_vision.launch" />

    <!-- 3. (Optional) Auto Exploration - Uncomment if you want the robot to drive itself -->
    <!-- <node pkg="ris" type="auto_explorer" name="auto_explorer" output="screen" /> -->

    <!-- 4. Visualization -->
    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find jetracer)/rviz/slam.rviz" />
</launch>
