<?xml version="1.0"?>
<launch>
  <param name="use_sim_time" value="false"/>

  <include file="$(find jetracer)/launch/gmapping.launch" />

  <node pkg="ris" type="youssef_slam" name="youssef_slam" output="screen">
    <param name="map_topic" value="/map"/>
    <param name="laptop_map_dir" value="/home/jetson/maps"/>
    <param name="laptop_map_name" value="mymap"/>
    <param name="robot_map_dir" value="/home/jetson/maps"/>
    <param name="robot_user" value="jetson"/>
    <param name="robot_ip" value="192.168.0.144"/>
    <param name="check_period_sec" value="2.0"/>
    <param name="changed_cells_threshold" value="20"/>
    <param name="stable_seconds_before_save" value="12.0"/>
    <param name="min_exploration_time_sec" value="90.0"/>
    <param name="gmapping_node_name" value="/slam_gmapping"/>
    <param name="stop_robot_before_save" value="true"/>
    <param name="exploration_done_topic" value="/exploration_done"/>
    <param name="publish_exploration_done" value="true"/>

    <param name="require_no_frontiers_to_finish" value="true"/>
    <param name="frontier_min_cluster_size" value="8"/>
    <param name="frontier_check_radius_m" value="6.0"/>
    <param name="frontier_unknown_neighbor_count_min" value="1"/>

  </node>
</launch>