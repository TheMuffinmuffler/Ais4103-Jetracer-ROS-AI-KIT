<launch>
    <arg name="global_planner_config" default="$(find ris)/config/navigation/global_planner_navfn.yaml"/>

    <rosparam command="load" file="$(find ris)/config/navigation/robot_footprint.yaml"/>
    <rosparam command="load" file="$(find ris)/config/navigation/costmap_common_params.yaml"/>
    <rosparam command="load" file="$(find ris)/config/navigation/global_costmap_params.yaml"/>
    <rosparam command="load" file="$(find ris)/config/navigation/local_costmap_params.yaml"/>
    <rosparam command="load" file="$(find ris)/config/navigation/move_base_params.yaml"/>
    <rosparam command="load" file="$(find ris)/config/navigation/dwa_local_planner_params.yaml"/>
    <rosparam command="load" file="$(arg global_planner_config)"/>

    <node pkg="move_base" type="move_base" name="move_base" output="screen"/>
</launch>